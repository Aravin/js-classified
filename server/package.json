{
  "name": "client",
  "version": "0.0.1",
  "description": "A classified website (free and open source)",
  "main": "index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prepare": "npx prisma generate",
    "dev": "ts-node-dev --respawn --transpile-only index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md,prisma}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aravin/js-classified.git"
  },
  "keywords": [
    "classified"
  ],
  "author": "Aravind Appadurai",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Aravin/js-classified/issues"
  },
  "homepage": "https://github.com/Aravin/js-classified#readme",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.18.0",
    "@sendgrid/mail": "^8.1.6",
    "@types/jsonwebtoken": "^9.0.10",
    "cloudinary": "^2.5.1",
    "fastify": "^5.1.0",
    "jimp": "0.16.13",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "nodemailer": "^7.0.10",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/nodemailer": "^7.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^9.1.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "nodemon": "^3.1.7",
    "prettier": "^3.2.5",
    "prisma": "^6.18.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  },
  "resolutions": {
    "picomatch": "^4.0.4",
    "fdir": "^6.5.0",
    "magicast": "^0.5.3"
  }
}
